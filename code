import tkinter as tk
from tkinter import ttk, messagebox
import random
import string
import json
import os
from datetime import datetime

HISTORY_FILE = "password_history.json"
MIN_LEN = 4
MAX_LEN = 32

class PasswordGeneratorApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Random Password Generator")
        self.root.geometry("620x500")
        self.root.resizable(False, False)

        self.history = []
        self._load_history()
        self._build_ui()

    def _build_ui(self):
        # --- 1. Ползунок длины ---
        settings = ttk.LabelFrame(self.root, text="Параметры пароля", padding=10)
        settings.pack(fill="x", padx=10, pady=5)

        ttk.Label(settings, text="Длина:").grid(row=0, column=0, sticky="w")
        self.length_var = tk.IntVar(value=12)
        self.slider = ttk.Scale(settings, from_=MIN_LEN, to=MAX_LEN, variable=self.length_var, orient="horizontal")
        self.slider.grid(row=0, column=1, padx=5, sticky="we")
        self.length_label = ttk.Label(settings, textvariable=self.length_var)
        self.length_label.grid(row=0, column=2, sticky="w")

        # --- 2. Чекбоксы (ровно как в задании) ---
        self.use_digits = tk.BooleanVar(value=True)
        self.use_letters = tk.BooleanVar(value=True)
        self.use_special = tk.BooleanVar(value=True)

        chk_frame = ttk.Frame(settings)
        chk_frame.grid(row=1, column=0, columnspan=3, sticky="w", pady=8)
        ttk.Checkbutton(chk_frame, text="Цифры", variable=self.use_digits).pack(side="left", padx=5)
        ttk.Checkbutton(chk_frame, text="Буквы", variable=self.use_letters).pack(side="left", padx=5)
        ttk.Checkbutton(chk_frame, text="Спецсимволы", variable=self.use_special).pack(side="left", padx=5)

        # --- 3. Кнопка генерации и вывод ---
        ctrl = ttk.Frame(self.root, padding=10)
        ctrl.pack(fill="x", padx=10)

        self.gen_btn = ttk.Button(ctrl, text="Сгенерировать", command=self.generate)
        self.gen_btn.pack(side="left", padx=(0, 5))

        self.password_var = tk.StringVar()
        self.entry = ttk.Entry(ctrl, textvariable=self.password_var, font=("Consolas", 11), width=30)
        self.entry.pack(side="left", fill="x", expand=True, padx=5)

        self.copy_btn = ttk.Button(ctrl, text="Копировать", command=self.copy_to_clipboard)
        self.copy_btn.pack(side="left")

        # --- 4. Таблица истории ---
        hist = ttk.LabelFrame(self.root, text="История генераций", padding=10)
        hist.pack(fill="both", expand=True, padx=10, pady=5)

        cols = ("#", "Password", "Len", "Types", "Time")
        self.tree = ttk.Treeview(hist, columns=cols, show="headings", height=8)
        for col, w, anchor in zip(cols, [30, 220, 40, 130, 140], ["center", "w", "center", "center", "center"]):
            self.tree.heading(col, text=col if col != "#" else "#")
            self.tree.column(col, width=w, anchor=anchor)

        scroll = ttk.Scrollbar(hist, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscroll=scroll.set)
        self.tree.pack(side="left", fill="both", expand=True)
        scroll.pack(side="right", fill="y")

        self._refresh_table()

    # ✅ 4. Проверка корректности ввода
    def generate(self):
        length = int(self.length_var.get())
        if not (MIN_LEN <= length <= MAX_LEN):
            messagebox.showwarning("Валидация", f"Длина должна быть от {MIN_LEN} до {MAX_LEN}.")
            return

        if not any([self.use_digits.get(), self.use_letters.get(), self.use_special.get()]):
            messagebox.showwarning("Валидация", "Выберите хотя бы один набор символов.")
            return

        # Формирование пула
        pool = ""
        types = []
        if self.use_letters.get():
            pool += string.ascii_letters
            types.append("Буквы")
        if self.use_digits.get():
            pool += string.digits
            types.append("Цифры")
        if self.use_special.get():
            pool += string.punctuation
            types.append("Спецсимволы")

        # ✅ 2. Генерация через random
        password = "".join(random.choice(pool) for _ in range(length))
        self.password_var.set(password)

        # Сохранение в историю
        record = {
            "password": password,
            "length": length,
            "types": ", ".join(types),
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        }
        self.history.insert(0, record)
        self._refresh_table()
        self._save_history()

    def copy_to_clipboard(self):
        pwd = self.password_var.get()
        if not pwd:
            messagebox.showinfo("Инфо", "Сначала сгенерируйте пароль.")
            return
        self.root.clipboard_clear()
        self.root.clipboard_append(pwd)
        self.root.update()
        messagebox.showinfo("Успех", "Пароль скопирован в буфер обмена!")

    def _refresh_table(self):
        for item in self.tree.get_children():
            self.tree.delete(item)
        for i, rec in enumerate(self.history, 1):
            self.tree.insert("", "end", values=(i, rec["password"], rec["length"], rec["types"], rec["timestamp"]))

    # ✅ 3. Сохранение и загрузка JSON
    def _save_history(self):
        try:
            with open(HISTORY_FILE, "w", encoding="utf-8") as f:
                json.dump({"history": self.history}, f, indent=2, ensure_ascii=False)
        except IOError as e:
            messagebox.showerror("Ошибка", f"Не удалось сохранить историю:\n{e}")

    def _load_history(self):
        if os.path.exists(HISTORY_FILE):
            try:
                with open(HISTORY_FILE, "r", encoding="utf-8") as f:
                    data = json.load(f)
                    self.history = data.get("history", [])
            except (json.JSONDecodeError, IOError):
                self.history = []

if __name__ == "__main__":
    root = tk.Tk()
    app = PasswordGeneratorApp(root)
    root.mainloop()
